<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="16dp" android:paddingEnd="16dp" android:background="#0A0A0A">
            <TextView android:id="@+id/btn_back" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="← Settings"
                android:textColor="#4A9EFF" android:textSize="15sp" android:padding="8dp"
                android:clickable="true" android:focusable="true"/>
        </LinearLayout>

        <!-- About ArizenOS -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="  ABOUT ARIZENOS" android:textColor="#666666" android:textSize="11sp"
            android:textStyle="bold" android:letterSpacing="0.15"
            android:paddingTop="16dp" android:paddingBottom="6dp" android:paddingStart="20dp"
            android:background="#000000"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#0D0D0D"
            android:padding="20dp" android:layout_marginBottom="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <View android:layout_width="4dp" android:layout_height="20dp"
                    android:background="#4A9EFF" android:layout_marginEnd="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ArizenOS Lite" android:textColor="#FFFFFF"
                    android:textSize="16sp" android:textStyle="bold"/>
            </LinearLayout>
            <TextView android:id="@+id/tv_about_build" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="#88FFFFFF"
                android:textSize="12sp" android:lineSpacingMultiplier="1.6"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- ARIZEN AI -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="  ARIZEN AI" android:textColor="#4A9EFF" android:textSize="11sp"
            android:textStyle="bold" android:letterSpacing="0.15"
            android:paddingTop="16dp" android:paddingBottom="6dp" android:paddingStart="20dp"
            android:background="#000000"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#0D0D0D"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="16dp" android:paddingBottom="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="AI Provider" android:textColor="#AAFFFFFF" android:textSize="12sp"
                android:layout_marginBottom="6dp"/>
            <Spinner android:id="@+id/sp_provider" android:layout_width="match_parent"
                android:layout_height="44dp" android:background="#1A1A1A"
                android:popupBackground="#1A1A1A" android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Model" android:textColor="#AAFFFFFF" android:textSize="12sp"
                android:layout_marginBottom="6dp"/>
            <Spinner android:id="@+id/sp_model" android:layout_width="match_parent"
                android:layout_height="44dp" android:background="#1A1A1A"
                android:popupBackground="#1A1A1A" android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="API Key" android:textColor="#AAFFFFFF" android:textSize="12sp"
                android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/et_api_key" android:layout_width="match_parent"
                android:layout_height="44dp" android:background="@drawable/input_bg"
                android:textColor="#FFFFFF" android:textColorHint="#44FFFFFF"
                android:hint="sk-... atau gsk-..." android:inputType="textPassword"
                android:textSize="13sp" android:paddingStart="12dp" android:paddingEnd="12dp"
                android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Custom Base URL  (opsional)" android:textColor="#AAFFFFFF"
                android:textSize="12sp" android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/et_custom_url" android:layout_width="match_parent"
                android:layout_height="44dp" android:background="@drawable/input_bg"
                android:textColor="#FFFFFF" android:textColorHint="#44FFFFFF"
                android:hint="https://api.groq.com/openai/v1" android:inputType="textUri"
                android:textSize="12sp" android:paddingStart="12dp" android:paddingEnd="12dp"
                android:layout_marginBottom="16dp"/>

            <TextView android:id="@+id/tv_status" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="Belum disimpan"
                android:textColor="#66FFFFFF" android:textSize="12sp"
                android:layout_marginBottom="14dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button android:id="@+id/btn_save" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:text="Simpan" android:textColor="#FFFFFF" android:textSize="13sp"
                    android:background="@drawable/btn_primary_bg" android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/btn_test" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:text="Test Koneksi" android:textColor="#4A9EFF" android:textSize="13sp"
                    android:background="@drawable/btn_outline_bg"/>
            </LinearLayout>
            <Button android:id="@+id/btn_clear_history" android:layout_width="match_parent"
                android:layout_height="40dp" android:text="Hapus Chat History"
                android:textColor="#FF6666" android:textSize="12sp"
                android:background="#00000000" android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- VOICE -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="  VOICE" android:textColor="#FF453A" android:textSize="11sp"
            android:textStyle="bold" android:letterSpacing="0.15"
            android:paddingTop="16dp" android:paddingBottom="6dp" android:paddingStart="20dp"
            android:background="#000000"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#0D0D0D">

            <LinearLayout android:layout_width="match_parent" android:layout_height="60dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="20dp" android:paddingEnd="20dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Hey Arizen — Wake Word" android:textColor="#FFFFFF"
                        android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Panggil Arizen tanpa buka layar dulu"
                        android:textColor="#66FFFFFF" android:textSize="11sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Gunakan mikrofon di background"
                        android:textColor="#44FF453A" android:textSize="10sp"/>
                </LinearLayout>
                <Switch android:id="@+id/sw_wake_word" android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="#FF453A" android:trackTint="#3A1A1A"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="#1A1A1A"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="20dp" android:paddingEnd="20dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Auto-Speak Jawaban" android:textColor="#FFFFFF"
                        android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Arizen baca jawaban dengan suara"
                        android:textColor="#66FFFFFF" android:textSize="11sp"/>
                </LinearLayout>
                <Switch android:id="@+id/sw_auto_speak_settings" android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="#4A9EFF" android:trackTint="#1A3A6A"/>
            </LinearLayout>
        </LinearLayout>

        <!-- PERFORMANCE -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="  PERFORMANCE" android:textColor="#00D4AA" android:textSize="11sp"
            android:textStyle="bold" android:letterSpacing="0.15"
            android:paddingTop="16dp" android:paddingBottom="6dp" android:paddingStart="20dp"
            android:background="#000000"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#0D0D0D">

            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="20dp" android:paddingEnd="20dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ZRAM  (512MB lz4)" android:textColor="#FFFFFF" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Swap virtual, hemat RAM fisik"
                        android:textColor="#66FFFFFF" android:textSize="11sp"/>
                </LinearLayout>
                <Switch android:id="@+id/sw_zram" android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="#4A9EFF" android:trackTint="#1A3A6A"/>
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#1A1A1A"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="20dp" android:paddingEnd="20dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Animasi Cepat  (0.5x)" android:textColor="#FFFFFF" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="UI lebih responsif"
                        android:textColor="#66FFFFFF" android:textSize="11sp"/>
                </LinearLayout>
                <Switch android:id="@+id/sw_anim_speed" android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="#4A9EFF" android:trackTint="#1A3A6A"/>
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#1A1A1A"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="20dp" android:paddingEnd="20dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Batasi Background Apps" android:textColor="#FFFFFF" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Max 8 proses background"
                        android:textColor="#66FFFFFF" android:textSize="11sp"/>
                </LinearLayout>
                <Switch android:id="@+id/sw_bg_limit" android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="#4A9EFF" android:trackTint="#1A3A6A"/>
            </LinearLayout>
        </LinearLayout>

        <!-- RAM & MEMORY -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="  RAM &amp; MEMORY" android:textColor="#FF9F0A" android:textSize="11sp"
            android:textStyle="bold" android:letterSpacing="0.15"
            android:paddingTop="16dp" android:paddingBottom="6dp" android:paddingStart="20dp"
            android:background="#000000"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#0D0D0D"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="14dp" android:paddingBottom="14dp">
            <TextView android:id="@+id/tv_ram_info" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="#88FFFFFF"
                android:textSize="12sp" android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.6" android:layout_marginBottom="12dp"/>
            <Button android:id="@+id/btn_ram_boost" android:layout_width="match_parent"
                android:layout_height="44dp" android:text="Boost RAM Sekarang"
                android:textColor="#FFFFFF" android:textSize="13sp"
                android:background="@drawable/btn_primary_bg"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="32dp"/>
    </LinearLayout>
</ScrollView>
