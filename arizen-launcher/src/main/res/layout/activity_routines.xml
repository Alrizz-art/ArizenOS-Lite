<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#000000" android:orientation="vertical">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp" android:background="#0A0A0A">
        <TextView android:id="@+id/btn_back" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="←"
            android:textColor="#4A9EFF" android:textSize="20sp" android:padding="8dp"
            android:clickable="true" android:focusable="true"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Arizen Routines" android:textColor="#FFFFFF"
                android:textSize="17sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tv_active_count" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="0 aktif"
                android:textColor="#00D4AA" android:textSize="11sp"/>
        </LinearLayout>
        <TextView android:id="@+id/btn_new_routine" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="+ Baru"
            android:textColor="#4A9EFF" android:textSize="13sp" android:textStyle="bold"
            android:padding="8dp" android:clickable="true" android:focusable="true"/>
    </LinearLayout>

    <!-- Tabs -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="40dp"
        android:orientation="horizontal">
        <LinearLayout android:id="@+id/tab_routines" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:background="#1A2A4A"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Rutinitas" android:textColor="#4A9EFF" android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/tab_log" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:background="#111111"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Riwayat" android:textColor="#666666" android:textSize="13sp"/>
        </LinearLayout>
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1C1C1E"/>

    <!-- Routine list -->
    <ScrollView android:id="@+id/scroll_list" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1" android:scrollbars="none">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="12dp">

            <TextView android:id="@+id/tv_empty" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:gravity="center"
                android:text="Belum ada rutinitas.\nTap '+ Baru' untuk membuat."
                android:textColor="#44FFFFFF" android:textSize="13sp"
                android:lineSpacingMultiplier="1.6" android:paddingTop="48dp"
                android:visibility="gone"/>

            <LinearLayout android:id="@+id/routine_list" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"/>
        </LinearLayout>
    </ScrollView>

    <!-- Run log -->
    <ScrollView android:id="@+id/scroll_log" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:visibility="gone" android:padding="16dp">
        <TextView android:id="@+id/tv_run_log" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="#88FFFFFF"
            android:textSize="12sp" android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.8"/>
    </ScrollView>
</LinearLayout>
