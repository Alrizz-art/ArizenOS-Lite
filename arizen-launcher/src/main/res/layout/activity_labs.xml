<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:orientation="vertical">

    <LinearLayout android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="@color/bg_surface">
        <TextView android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&lt;"
            android:textColor="@color/text_secondary"
            android:textSize="26sp"
            android:paddingEnd="16dp"
            android:clickable="true"
            android:focusable="true"/>
        <LinearLayout android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ArizenLabs"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"/>
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fitur Eksperimental"
                android:textColor="@color/accent_labs"
                android:textSize="11sp"
                android:fontFamily="sans-serif-light"/>
        </LinearLayout>
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="* LABS"
            android:textColor="@color/accent_labs"
            android:textSize="11sp"
            android:background="@drawable/labs_card_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/accent_labs_dim"/>

    <ScrollView android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:overScrollMode="never">
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout android:id="@+id/card_agent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">
                <View android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/ai_orb_bg"
                    android:layout_marginEnd="16dp"/>
                <LinearLayout android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Arizen Agent"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="AI bisa kontrol OS, buka app, baca notifikasi"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-light"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=">"
                    android:textColor="@color/accent_blue"
                    android:textSize="22sp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/card_sysmon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">
                <View android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/labs_card_bg"
                    android:layout_marginEnd="16dp"/>
                <LinearLayout android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="System Monitor"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView android:id="@+id/tv_ram"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RAM: --"
                            android:textColor="@color/accent_labs"
                            android:textSize="12sp"
                            android:fontFamily="monospace"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="RAM, CPU, suhu, proses aktif"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-light"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=">"
                    android:textColor="@color/accent_labs"
                    android:textSize="22sp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/card_ambience"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">
                <View android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/ai_bubble_bg"
                    android:layout_marginEnd="16dp"/>
                <LinearLayout android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI Ambience"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="Arizen aktif di background, siap dipanggil kapan saja"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-light"/>
                </LinearLayout>
                <Switch android:id="@+id/switch_ambience"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"/>
            </LinearLayout>

            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AKSI CEPAT"
                android:textColor="@color/accent_blue"
                android:textSize="10sp"
                android:letterSpacing="0.18"
                android:textAllCaps="true"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp"
                android:layout_marginTop="8dp"/>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout android:id="@+id/quick_summarize"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="[Ringkas]" android:textColor="@color/text_secondary" android:textSize="11sp"
                        android:fontFamily="sans-serif-light"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/quick_translate"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="[Terjemah]" android:textColor="@color/text_secondary" android:textSize="11sp"
                        android:fontFamily="sans-serif-light"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/quick_code"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="[Kode]" android:textColor="@color/text_secondary" android:textSize="11sp"
                        android:fontFamily="sans-serif-light"/>
                </LinearLayout>
            </LinearLayout>

            <TextView android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="ArizenOS Lite v1.0 * ArizenLabs * SM-T295"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"
                android:gravity="center"
                android:fontFamily="sans-serif-light"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
